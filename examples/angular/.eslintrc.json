{
  "root": true,
  "ignorePatterns": ["projects/**/*"],
  "overrides": [
    {
      "files": ["*.ts"],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ],
      "rules": {
        "no-restricted-imports": ["error", {
          "patterns": [
            "(modules)/device-management/*",
            "(modules)/device-verification/*"
          ]
        }]
      }
    }
  ]
}
